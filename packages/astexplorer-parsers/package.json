{
  "name": "astexplorer-parsers",
  "version": "1.0.0",
  "description": "Parser definitions for astexplorer",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./swc.wasm": "./dist/swc.wasm",
    "./syn.wasm": "./dist/syn.wasm",
    "./go.wasm": "./dist/go.wasm",
    "./monkey.wasm": "./dist/monkey.wasm",
    "./dist/*": "./dist/*"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--openssl-legacy-provider node build.js --production",
    "build-dev": "NODE_OPTIONS=--openssl-legacy-provider node build.js",
    "typecheck": "tsc --noEmit",
    "test": "npx vitest run",
    "test:update": "npx vitest run --update"
  },
