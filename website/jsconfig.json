{
  "compilerOptions": {
    "checkJs": true,
    "strict": false,
    "jsx": "react",
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": false,
    "noImplicitAny": true
  },
  "include": ["src/**/*.js", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
