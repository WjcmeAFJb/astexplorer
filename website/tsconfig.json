{
  "compilerOptions": {
    "strict": false,
    "jsx": "react",
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "resolveJsonModule": false,
    "noImplicitAny": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "astexplorer-parsers": ["../packages/astexplorer-parsers/dist/index"],
      "astexplorer-parsers/src/types": ["../packages/astexplorer-parsers/dist/types"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.js", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
